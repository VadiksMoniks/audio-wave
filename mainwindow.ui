   <widget class="QSlider" name="audioSlider">
    <property name="geometry">
     <rect>
      <x>320</x>
      <y>380</y>
      <width>310</width>
      <height>20</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">QSlider::groove:horizontal {
    height: 12px;                 /* толщина полосы */
    background: #555555;          /* тёмно-серый цвет */
    border-radius: 6px;           /* скругление краёв */
}

QSlider::handle:horizontal {
    width: 0px;                   /* убираем видимый круг */
    height: 0px;
    margin: 0px;
    background: transparent;       /* на всякий случай */
}

QSlider::sub-page:horizontal {
    background: #777777;          /* цвет заполненной части */
    border-radius: 6px;
}

QSlider::add-page:horizontal {
    background: #555555;          /* цвет оставшейся части */
    border-radius: 6px;
}</string>
    </property>
    <property name="orientation">
     <enum>Qt::Orientation::Horizontal</enum>
    </property>
