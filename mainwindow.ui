    <property name="styleSheet">
     <string notr="true">QPushButton {
    /* Фиксированный размер для строгой формы круга */
    min-width: 60px;
    max-width: 60px;
    min-height: 60px;
    max-height: 60px;

    /* Радиус = половина стороны */
    border-radius: 30px; 
    background-color: rgba(255,255,255, 50);
    color: #ffffff;
}

QPushButton:hover {
	background-color: rgba(255,255,255, 120);
}
/* Эффект при нажатии */
QPushButton:pressed {
	background-color: rgba(255,255,255, 180);
}</string>
